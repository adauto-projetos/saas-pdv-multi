# Banco Postgres local (Docker Desktop). Suba com: docker compose up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pdv

# ─── PRODUÇÃO (não usar em local) ──────────────────────────────────────────
# Senha do Postgres em produção. O docker-compose.prod.yml a injeta no container
# do banco E a usa para montar a DATABASE_URL dinamicamente
# (postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/pdv).
# Local usa "postgres:postgres" hardcoded acima; produção EXIGE valor forte e único.
# POSTGRES_PASSWORD=
#
# Em produção também são OBRIGATÓRIAS (sem default seguro): SESSION_SECRET (abaixo)
# e as 5 vars R2_* (abaixo). Valide-as com `npm run r2:check` antes do deploy.
# ───────────────────────────────────────────────────────────────────────────

# Segredo para assinar o cookie de sessão. Troque por um valor aleatório e longo.
# Gerar um: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-um-valor-aleatorio-bem-longo

# Cloudflare R2 (object storage S3-compatible) — fotos de produto (feature 0016F).
# Credenciais ficam SÓ aqui/no ambiente, nunca no código nem no Git (RNF02).
# R2_ACCOUNT_ID: id da conta Cloudflare (compõe o endpoint https://<id>.r2.cloudflarestorage.com)
R2_ACCOUNT_ID=
# Nome do bucket onde as fotos são gravadas (listagem do bucket deve ficar DESABILITADA — RN03)
R2_BUCKET=pdv-product-images
# Par de chaves do token de API R2 (escopo de leitura/escrita no bucket)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# URL pública do bucket (domínio r2.dev ou domínio custom), sem barra final.
# A foto é servida por esta URL + a chave do objeto (RN03/RN04).
R2_PUBLIC_URL=
